{
  "name": "dash-board-root",
  "version": "1.0.0",
  "description": "Root orchestrator for Launch Tracker Dashboard",
  "scripts": {
    "dev:backend": "cd backend && venv\\Scripts\\python.exe manage.py runserver",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
